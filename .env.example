# Telegram Bot Configuration
# Get your bot token from @BotFather on Telegram

TELEGRAM_BOT_TOKEN=your_bot_token_here

# Optional: Admin user IDs who can use admin commands (comma-separated)
# ADMIN_IDS=123456789,987654321

# Optional: Log violations to a channel (channel ID or username)
# LOG_CHANNEL_ID=@your_log_channel or -1001234567890
